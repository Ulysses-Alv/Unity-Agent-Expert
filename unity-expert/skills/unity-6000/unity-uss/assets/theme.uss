/* ===== Unity UI Toolkit - USS Theme Template ===== */
/* Unity 6000.3 LTS compatible */

/* ===== Variables (Custom Properties) ===== */
:root {
    --primary-color: rgb(68, 138, 255);
    --secondary-color: rgb(150, 150, 150);
    --background-color: rgb(30, 30, 30);
    --surface-color: rgb(50, 50, 50);
    --text-color: rgb(255, 255, 255);
    --text-muted: rgb(180, 180, 180);
    --border-color: rgb(80, 80, 80);
    --spacing-sm: 8px;
    --spacing-md: 16px;
    --spacing-lg: 24px;
    --font-size-sm: 12px;
    --font-size-md: 16px;
    --font-size-lg: 24px;
    --border-radius: 8px;
}

/* ===== Root Container ===== */
.root-container {
    flex-direction: column;
    width: 100%;
    height: 100%;
    background-color: var(--background-color);
    color: var(--text-color);
}

/* ===== Header ===== */
.header {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-md);
    background-color: var(--surface-color);
    border-bottom-width: 1px;
    border-bottom-color: var(--border-color);
}

.title {
    font-size: var(--font-size-lg);
    -unity-font-style: bold;
}

.close-button {
    width: 30px;
    height: 30px;
    font-size: var(--font-size-sm);
}

.close-button:hover {
    background-color: rgb(200, 50, 50);
}

/* ===== Content ===== */
.content {
    flex-direction: column;
    flex-grow: 1;
    padding: var(--spacing-lg);
    gap: var(--spacing-md);
    overflow: scroll-vertical;
}

.description {
    font-size: var(--font-size-md);
    color: var(--text-muted);
}

/* ===== Footer ===== */
.footer {
    flex-direction: row;
    justify-content: flex-end;
    gap: var(--spacing-sm);
    padding: var(--spacing-md);
    background-color: var(--surface-color);
    border-top-width: 1px;
    border-top-color: var(--border-color);
}

/* ===== Buttons ===== */
.primary-button {
    background-color: var(--primary-color);
    color: white;
    font-size: var(--font-size-md);
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--border-radius);
}

.primary-button:hover {
    background-color: rgb(88, 158, 255);
}

.primary-button:active {
    background-color: rgb(48, 118, 235);
}

.secondary-button {
    background-color: var(--secondary-color);
    color: white;
    font-size: var(--font-size-md);
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--border-radius);
}

.secondary-button:hover {
    background-color: rgb(170, 170, 170);
}

/* ===== Card Pattern ===== */
.card {
    background-color: var(--surface-color);
    border-radius: var(--border-radius);
    padding: var(--spacing-md);
    flex-direction: column;
    gap: var(--spacing-sm);
}

.card-title {
    font-size: var(--font-size-md);
    -unity-font-style: bold;
}

.card-content {
    font-size: var(--font-size-sm);
    color: var(--text-muted);
}

/* ===== Transitions ===== */
.animated {
    transition: background-color 0.3s ease, opacity 0.3s ease;
}

.animated:hover {
    opacity: 0.8;
}
